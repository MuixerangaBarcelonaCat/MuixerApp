NODE_ENV=production
PORT=3000

# Database — PostgreSQL (connects to postgres container via Docker network)
DB_SSL=false
POSTGRES_USER=muixer_prod
POSTGRES_PASSWORD=change-me-strong-random-password
POSTGRES_DB=muixer_prod
DATABASE_URL=postgresql://muixer_prod:change-me-strong-random-password@postgres:5432/muixer_prod

# CORS — only allow your dashboard and PWA domains
CORS_ORIGINS=https://dashboard.yourdomain.com,https://app.yourdomain.com

# Legacy API (sync) — keep for data import if needed
LEGACY_API_URL=https://colla-muixeranguera.appsistencia.cat
LEGACY_API_USERNAME=XXXXXX
LEGACY_API_PASSWORD=XXXXXX

# JWT — Access Token
JWT_SECRET=change-me-production-strong-random-secret-64chars
JWT_ACCESS_TTL=900

# JWT — Refresh Token (MUST be different from JWT_SECRET)
JWT_REFRESH_SECRET=change-me-production-different-strong-secret-64chars
# 28800 = 8 hours
JWT_REFRESH_TTL_DASHBOARD=28800
# 604800 = 7 days
JWT_REFRESH_TTL_PWA=604800

# Refresh token cookie name
REFRESH_TOKEN_COOKIE=muixer_rt

# Bootstrap setup endpoint — REMOVE from .env after first admin user is created
# SETUP_TOKEN=change-me-random-uuid
