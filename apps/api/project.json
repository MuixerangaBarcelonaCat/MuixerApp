{
  "name": "api",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/api/src",
  "tags": ["type:app", "scope:api"],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "dependsOn": ["^build"],
      "options": {
        "target": "node",
        "compiler": "tsc",
        "outputPath": "dist/apps/api",
        "main": "apps/api/src/main.ts",
        "tsConfig": "apps/api/tsconfig.app.json",
        "assets": ["apps/api/src/assets"],
        "webpackConfig": "apps/api/webpack.config.js"
      },
      "configurations": {
        "production": {
          "optimization": true,
          "extractLicenses": true,
          "inspect": false,
          "fileReplacements": [
            {
              "replace": "apps/api/src/environments/environment.ts",
              "with": "apps/api/src/environments/environment.prod.ts"
            }
          ]
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "inspect": false
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api:build",
        "watch": true,
        "inspect": false
      },
      "configurations": {
        "production": {
          "buildTarget": "api:build:production",
          "inspect": false,
          "watch": false
        },
        "development": {
          "buildTarget": "api:build:development",
          "inspect": false
        },
        "no-watch": {
          "buildTarget": "api:build:development",
          "inspect": false,
          "watch": false
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/api/jest.config.ts",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    },
    "seed-seasons": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.base.json ts-node --compilerOptions '{\"module\":\"commonjs\",\"target\":\"es2021\",\"moduleResolution\":\"node\",\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' --transpileOnly -r tsconfig-paths/register apps/api/src/modules/database/scripts/seed-seasons.script.ts",
        "cwd": "."
      }
    },
    "reset-figure-data": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.base.json ts-node --compilerOptions '{\"module\":\"commonjs\",\"target\":\"es2021\",\"moduleResolution\":\"node\",\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' --transpileOnly -r tsconfig-paths/register apps/api/src/modules/database/scripts/reset-figure-data.script.ts",
        "cwd": "."
      }
    },
    "seed-figures-pd4": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.base.json ts-node --compilerOptions '{\"module\":\"commonjs\",\"target\":\"es2021\",\"moduleResolution\":\"node\",\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' --transpileOnly -r tsconfig-paths/register apps/api/src/modules/database/scripts/seed-figures/pd4.figure-seed.ts",
        "cwd": "."
      }
    },
    "seed-figures-pd4-insert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.base.json ts-node --compilerOptions '{\"module\":\"commonjs\",\"target\":\"es2021\",\"moduleResolution\":\"node\",\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' --transpileOnly -r tsconfig-paths/register apps/api/src/modules/database/scripts/seed-figures/pd4.figure-seed.ts --insert",
        "cwd": "."
      }
    },
    "seed-figures-pd3": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.base.json ts-node --compilerOptions '{\"module\":\"commonjs\",\"target\":\"es2021\",\"moduleResolution\":\"node\",\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' --transpileOnly -r tsconfig-paths/register apps/api/src/modules/database/scripts/seed-figures/pd3.figure-seed.ts",
        "cwd": "."
      }
    },
    "seed-figures-pd3-insert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.base.json ts-node --compilerOptions '{\"module\":\"commonjs\",\"target\":\"es2021\",\"moduleResolution\":\"node\",\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' --transpileOnly -r tsconfig-paths/register apps/api/src/modules/database/scripts/seed-figures/pd3.figure-seed.ts --insert",
        "cwd": "."
      }
    },
    "seed-figures-pd3-creu": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.base.json ts-node --compilerOptions '{\"module\":\"commonjs\",\"target\":\"es2021\",\"moduleResolution\":\"node\",\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' --transpileOnly -r tsconfig-paths/register apps/api/src/modules/database/scripts/seed-figures/pd3-creu.figure-seed.ts",
        "cwd": "."
      }
    },
    "seed-figures-pd3-creu-insert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "TS_NODE_PROJECT=tsconfig.base.json ts-node --compilerOptions '{\"module\":\"commonjs\",\"target\":\"es2021\",\"moduleResolution\":\"node\",\"experimentalDecorators\":true,\"emitDecoratorMetadata\":true}' --transpileOnly -r tsconfig-paths/register apps/api/src/modules/database/scripts/seed-figures/pd3-creu.figure-seed.ts --insert",
        "cwd": "."
      }
    }
  }
}
